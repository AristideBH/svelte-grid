{
  "name": "svelte-grid",
  "version": "6.0.0",
  "description": "A responsive, draggable and resizable grid layout, for Svelte.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaheqelyan/svelte-grid.git"
  },
  "bugs": {
    "url": "https://github.com/vaheqelyan/svelte-grid/issues"
  },
  "homepage": "https://github.com/vaheqelyan/svelte-grid#readme",
  "keywords": [
    "svelte",
    "svelte5",
    "grid",
    "drag",
    "draggable",
    "resize",
    "resizable",
    "fluid",
    "responsive"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "package": "svelte-package -i src/lib",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./helper": {
      "types": "./dist/utils/helper.d.ts",
      "import": "./dist/utils/helper.js",
      "require": "./dist/utils/helper.js"
    }
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "helper": [
        "./dist/utils/helper.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tweakpane": "^4.0.5",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.0"
  }
}
